local pid = require("src.pid")

local Core = {}

function Core.init(r)
    r.pid = pid.new()
    r.state = {
        stored = 0,
        capacity = 1,
        lastRFT = 0
    }
end

function Core.update(r)
    local re = r.reactor

    r.state.stored = re.getEnergyStored()
    r.state.capacity = re.getEnergyCapacity()
    r.state.lastRFT = re.getEnergyProducedLastTick()

    local pct = (r.state.stored / r.state.capacity) * 100
    local target = (r.min + r.max) / 2

    local error = target - pct

    local rod = pid.step(r.pid, error)
    rod = math.max(0, math.min(100, rod))

    re.setActive(true)
    re.setAllControlRodLevels(rod)
end

return Core
